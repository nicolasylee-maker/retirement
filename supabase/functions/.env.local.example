# Local development secrets for Supabase Edge Functions
#
# Copy this file to .env.local and fill in your values:
#   cp supabase/functions/.env.local.example supabase/functions/.env.local
#
# .env.local is gitignored — never commit it.
# See docs/stripe-local-testing.md for full setup instructions.

# Stripe test mode keys (from Stripe Dashboard → Developers → API Keys)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret — generated by `stripe listen --print-secret`
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Supabase project credentials (from Supabase Dashboard → Project Settings → API)
SUPABASE_URL=https://kovxoeovijedvxmulbke.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# App redirect URL for Stripe checkout success/cancel redirects
APP_URL=http://localhost:5173
