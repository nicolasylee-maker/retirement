# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin
VITE_ADMIN_EMAIL=your@email.com

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# Sentry
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Gemini API Key — SERVER-SIDE ONLY (Supabase Edge Function secret)
# Never add a VITE_ prefix; this must never be exposed to the browser.
# Set via: supabase secrets set GEMINI_API_KEY=AIza...
# GEMINI_API_KEY=AIza...
