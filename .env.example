# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# NEVER expose service_role key in browser — only used in Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin (email that can access /admin)
VITE_ADMIN_EMAIL=your@email.com

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
VITE_STRIPE_PRICE_MONTHLY=price_your-monthly-id
VITE_STRIPE_PRICE_YEARLY=price_your-yearly-id

# Resend (SMTP for magic link emails — only in Supabase Edge Functions)
RESEND_API_KEY=re_your-key-here

# Gemini (server-side only — never expose with VITE_ prefix)
GEMINI_API_KEY=your-gemini-api-key-here

# Sentry error monitoring (production only — leave blank in local dev)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Deployment environment badge (local | dev | prod — omit in production deployments)
VITE_ENV=
